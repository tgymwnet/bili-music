{
  "name": "bili-music",
  "version": "1.0.0",
  "description": "B站音乐播放器",
  "productName": "BiliMusic",
  "author": "",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "node electron/dev.cjs",
    "gen-icon": "node electron/gen-icon.cjs",
    "electron:build": "node electron/gen-icon.cjs && vite build && electron-builder"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.13.5",
    "howler": "^2.2.4",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "quasar": "^2.18.6",
    "sass": "^1.97.3",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@quasar/app-vite": "^1.11.0",
    "@quasar/vite-plugin": "^1.10.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "autoprefixer": "^10.4.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue-tsc": "^3.2.5"
  },
  "main": "electron/main.cjs",
  "engines": {
    "node": "^20 || ^18"
  },
  "build": {
    "appId": "com.bilimusic.app",
    "productName": "BiliMusic",
    "copyright": "Copyright © 2025 BiliMusic",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/icon.png"
    ],
    "extraResources": [
      { "from": "dist", "to": "dist" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BiliMusic"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.music"
    }
  }
}
